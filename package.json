{
	"name": "my-page",
	"version": "1.11.2",
	"private": true,
	"author": "Arseny Garelshev <me@arsga.eu>",
	"description": "App to host on my website",
	"license": "0BSD",
	"type": "module",
	"scripts": {
		"dev": "next dev --experimental-next-config-strip-types",
		"build": "next build --experimental-next-config-strip-types",
		"start": "next start --experimental-next-config-strip-types",
		"lint": "biome lint",
		"test": "node --test",
		"format": "biome format --write",
		"typecheck": "tsc",
		"fullcheck": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
		"update-deps": "corepack use pnpm@10 && pnpm up -L"
	},
	"dependencies": {
		"next": "16.1.6",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@tsconfig/next": "2.0.5",
		"@types/node": "25.3.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"typescript": "5.9.3"
	},
	"browserslist": [
		"defaults and fully supports es6-module",
		"maintained node versions"
	],
	"packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}
