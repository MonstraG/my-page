{
	"name": "my-page",
	"version": "1.11.1",
	"private": true,
	"author": "Arseny Garelshev <me@arsga.eu>",
	"description": "App to host on my website",
	"license": "0BSD",
	"type": "module",
	"scripts": {
		"dev": "next dev --experimental-next-config-strip-types",
		"build": "next build --experimental-next-config-strip-types",
		"start": "next start --experimental-next-config-strip-types",
		"lint": "biome lint",
		"test": "node --test",
		"format": "biome format --write",
		"typecheck": "tsc",
		"fullcheck": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
		"update-deps": "corepack use pnpm@10 && pnpm up -L"
	},
	"dependencies": {
		"next": "16.1.6",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.1",
		"@tsconfig/next": "2.0.5",
		"@types/node": "25.2.3",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"typescript": "5.9.3"
	},
	"browserslist": [
		"defaults and fully supports es6-module",
		"maintained node versions"
	],
	"packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937"
}
