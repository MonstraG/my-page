{
	"name": "my-page",
	"version": "1.14.1",
	"private": true,
	"author": "Arseny Garelshev <me@arsga.eu>",
	"description": "App to host on my website",
	"license": "0BSD",
	"type": "module",
	"scripts": {
		"dev": "next dev --experimental-next-config-strip-types",
		"build": "next build --experimental-next-config-strip-types",
		"start": "next start --experimental-next-config-strip-types",
		"lint": "biome lint",
		"test": "node --test",
		"format": "biome format --write",
		"typecheck": "tsc",
		"fullcheck": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
		"update-deps": "corepack use pnpm@11 && pnpm up -L"
	},
	"dependencies": {
		"next": "16.2.6",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@tsconfig/next": "2.0.6",
		"@types/node": "25.8.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"typescript": "6.0.3"
	},
	"browserslist": [
		"defaults and fully supports es6-module",
		"maintained node versions"
	],
	"packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
