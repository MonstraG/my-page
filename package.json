{
	"name": "my-page",
	"version": "1.14.1",
	"private": true,
	"author": "Arseny Garelshev <me@arsga.eu>",
	"description": "App to host on my website",
	"license": "0BSD",
	"type": "module",
	"scripts": {
		"dev": "next dev --experimental-next-config-strip-types",
		"build": "next build --experimental-next-config-strip-types",
		"start": "next start --experimental-next-config-strip-types",
		"lint": "biome lint",
		"test": "node --test",
		"format": "biome format --write",
		"typecheck": "tsc",
		"fullcheck": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
		"update-deps": "corepack use pnpm@10 && pnpm up -L"
	},
	"dependencies": {
		"next": "16.2.6",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@tsconfig/next": "2.0.6",
		"@types/node": "25.6.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"typescript": "6.0.3"
	},
	"browserslist": [
		"defaults and fully supports es6-module",
		"maintained node versions"
	],
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
