{
	"name": "my-page",
	"version": "1.14.1",
	"private": true,
	"author": "Arseny Garelshev <me@arsga.eu>",
	"description": "App to host on my website",
	"license": "0BSD",
	"type": "module",
	"scripts": {
		"dev": "next dev --experimental-next-config-strip-types",
		"build": "next build --experimental-next-config-strip-types",
		"start": "next start --experimental-next-config-strip-types",
		"lint": "biome lint",
		"test": "node --test",
		"format": "biome format --write",
		"typecheck": "tsc",
		"fullcheck": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
		"update-deps": "corepack use pnpm@11 && pnpm up -L"
	},
	"dependencies": {
		"next": "16.2.6",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@tsconfig/next": "2.0.6",
		"@types/node": "25.6.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"babel-plugin-react-compiler": "1.0.0",
		"typescript": "6.0.3"
	},
	"browserslist": [
		"defaults and fully supports es6-module",
		"maintained node versions"
	],
	"packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
